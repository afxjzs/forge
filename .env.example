# Required
ANTHROPIC_API_KEY=sk-ant-...         # Anthropic API key (for LLM-powered bot features)

# Optional — have sensible defaults
FORGE_BOT_TOKEN=                     # Telegram bot token (or put in ~/.forge-bot-token)
FORGE_CHAT_ID=                       # Telegram chat ID for notifications
DOCKER_OPS_TOKEN=                    # Token for docker-ops API (if using deploy features)
FORGE_API_URL=http://127.0.0.1:8773  # forge-api URL
FORGE_NOTIFY_PORT=8774               # Port for notification webhook
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514  # Model for bot LLM calls
GITHUB_WEBHOOK_SECRET=                     # Shared secret for GitHub webhook HMAC verification
