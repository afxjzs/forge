[Unit]
Description=forge-api — pipeline project registry and orchestrator trigger
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/nexus/infra/dev-pipeline/api
EnvironmentFile=%h/nexus/infra/dev-pipeline/.env
ExecStart=%h/.local/bin/uv run uvicorn api:app --host 0.0.0.0 --port 8773
Restart=on-failure
RestartSec=5
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
